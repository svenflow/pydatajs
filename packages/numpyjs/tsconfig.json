{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "noUncheckedIndexedAccess": false,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "types": ["@webgpu/types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "benchmarks", "crates", "target"]
}
